{
  "model": "claude-opus-4-6",
  "maxTokens": 200000,
  "temperature": 0.1,
  "permissions": {
    "shell": true,
    "fileSystem": true,
    "mcp": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "\"$CLAUDE_PROJECT_DIR\"/plugins/agentic-sdlc/claude/hooks/block-destructive.sh"
          }
        ]
      }
    ]
  }
}
